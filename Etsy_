n","        new_height = driver.execute_script(\"return document.body.scrollHeight\")\n","        if new_height == last_height:\n","            break\n","        last_height = new_height\n","\n","\n","def scrape_etsy_search(query, num_pages=1, pause=3.0):\n","    \"\"\"\n","    Scrape Etsy search results for a given query.\n","    Returns a pandas DataFrame with: title, price, shop, url, page.\n","    \"\"\"\n","    all_rows = []\n","\n","    for page in range(1, num_pages + 1):\n","        driver = create_driver()\n","        q = quote_plus(query)\n","        url = f\"https://www.etsy.com/search?q={q}&page={page}\"\n","\n","        print(f\"\\nOpening page {page}: {url}\")\n","        driver.get(url)\n","        time.sleep(pause)\n","\n","        # Close cookie banner\n","        try:\n","            WebDriverWait(driver, 5).until(\n","                EC.element_to_be_clickable(\n","                    (By.XPATH, \"//button[contains(., 'Accept') or contains(., 'OK')]\")\n","                )\n","            ).click()\n","        except:\n","            pass\n","\n","        # Scroll to load all products\n","        scroll_page(driver)\n","\n","        # Etsy listing card selector (verified)\n","        card_xpath = (\"//div[contains(@class,'js-merch-stash-check-listing') and \"\n","                      \"contains(@class,'v2-listing-card') and \"\n","                      \"contains(@class,'wt-mb-xs-2')]\")\n","\n","        # Wait for at least 1 card\n","        try:\n","            WebDriverWait(driver, 20).until(\n","                EC.presence_of_element_located((By.XPATH, card_xpath))\n","            )\n","        except Exception as e:\n","            print(f\"Could not find product cards on page {page}: {e}\")\n","            driver.quit()\n","            continue\n","\n","        cards = driver.find_elements(By.XPATH, card_xpath)\n","        print(f\"Loaded {len(cards)} cards on page {page}\")\n","\n","        for c in cards:\n","            try:\n","                # Title & URL\n","                link_el = c.find_element(By.CSS_SELECTOR, \"a.listing-link\")\n","                url_ = link_el.get_attribute(\"href\")\n","\n","                try:\n","                    title_ = link_el.find_element(By.CSS_SELECTOR, \"h3\").text.strip()\n","                except:\n","                    title_ = None\n","\n","                # Price\n","                try:\n","                    price_ = c.find_element(\n","                        By.CSS_SELECTOR, \"span.currency-value\"\n","                    ).text.strip()\n","                except:\n","                    price_ = None\n","\n","                # Shop\n","                try:\n","                    shop_el = c.find_element(\n","                        By.CSS_SELECTOR,\n","                        \"p.text-gray-lighter, p.wt-text-truncate\"\n","                    )\n","                    shop_ = shop_el.text.strip()\n","                except:\n","                    shop_ = None\n","\n","                all_rows.append({\n","                    \"title\": title_,\n","                    \"price\": price_,\n","                    \"shop\": shop_,\n","                    \"url\": url_,\n","                    \"page\": page,\n","                })\n","\n","            except Exception:\n","                continue\n","\n","        driver.quit()\n","\n","    return pd.DataFrame(all_rows)\n"],"metadata":{"id":"3Sta6QT5BwlQ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["!apt-get update\n","!apt install chromium-browser\n","!chromium-browser --version\n","!pip install selenium\n","# import selium\n","from selenium import webdriver\n","from selenium.webdriver.chrome.options import Options\n","from selenium.webdriver.chrome.service import Service\n","from selenium.webdriver.common.by import By\n","\n","\n","# Make browser headless\n","chrome_options = Options()\n","chrome_options.add_argument('--headless')  # Run Chrome in headless mode\n","chr