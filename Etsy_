"//button[contains(., 'Accept') or contains(., 'OK')]\")\n","                )\n","            )\n","            cookie_btn.click()\n","            time.sleep(1)\n","        except Exception:\n","            pass  # ignore if no banner\n","\n","        # Wait until at least one listing card appear\\\\\n","        try:\n","            WebDriverWait(driver, 250).until(\n","                EC.presence_of_element_located(\n","                    (By.CSS_SELECTOR, \"li.wt-list-unstyled div.v2-listing-card\")\n","                    # js-merch-stash-check-listing v2-listing-card wt-mb-xs-2\n","                )\n","            )\n","        except Exception as e:\n","            print(f\"Could not find product cards on page {page}: {e}\")\n","            driver.quit()\n","            continue\n","\n","        cards = driver.find_elements(\n","            By.CSS_SELECTOR,\n","            \"li.wt-list-unstyled div.v2-listing-card\"\n","        )\n","        print(\"Found cards:\", len(cards))\n","\n","        for c in cards:\n","            try:\n","                # URL + title\n","                link_el = c.find_element(By.CSS_SELECTOR, \"a.listing-link\")\n","                listing_url = link_el.get_attribute(\"href\")\n","\n","                try:\n","                    title_el = link_el.find_element(By.CSS_SELECTOR, \"h3\")\n","                    title = title_el.text.strip()\n","                except Exception:\n","                    title = None\n","\n","                # Price\n","                try:\n","                    price_el = c.find_element(\n","                        By.CSS_SELECTOR,\n","                        \"span.currency-value\"\n","                    )\n","                    price = price_el.text.strip()\n","                except Exception:\n","                    price = None\n","\n","                # Shop name\n","                try:\n","                    shop_el = c.find_element(\n","                        By.CSS_SELECTOR,\n","  